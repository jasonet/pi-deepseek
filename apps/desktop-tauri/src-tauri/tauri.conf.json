{
  "$schema": "https://raw.githubusercontent.com/nicepkg/vscode-tauri/main/schemas/tauri.conf.schema.json",
  "productName": "Pi-Deepseek",
  "version": "2.6.8",
  "identifier": "com.pi-deepseek.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build:bundle"
  },
  "app": {
    "windows": [
      {
        "title": "Pi-Deepseek",
        "width": 1480,
        "height": 980,
        "minWidth": 1200,
        "minHeight": 760,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "sidecar/server.mjs": "sidecar/server.mjs",
      "sidecar/node": "sidecar/node",
      "sidecar/node_modules": "sidecar/node_modules"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Deepseek GUI app for elegant pi coding agent",
    "longDescription": "Pi-Deepseek is a desktop GUI client for the pi coding agent. Built with Rust + Tauri 2.",
    "copyright": "Copyright 2026 Yiding by HKEZ",
    "macOS": {
      "minimumSystemVersion": "12.0"
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0"]
      }
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
