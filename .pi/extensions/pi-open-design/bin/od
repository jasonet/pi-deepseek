#!/bin/bash
# Pi-Deepseek Open Design Launcher v0.9
# Auto-detects Open Design project and launches daemon.
# Priority:
#   1. OPEN_DESIGN_OD_BIN env var
#   2. ./node_modules/.bin/od (installed via npm/pnpm)
#   3. ../open-design/apps/daemon/bin/od.mjs (sibling repo)

set -e

# Resolve node binary
NODE_BIN="${NODE_BIN:-}"
if [ -z "$NODE_BIN" ]; then
  NODE_BIN=$(which node 2>/dev/null || echo "")
fi
if [ -z "$NODE_BIN" ]; then
  for candidate in \
    /opt/homebrew/bin/node \
    /opt/homebrew/Cellar/node@22/*/bin/node \
    /opt/homebrew/Cellar/node@20/*/bin/node \
    /usr/local/bin/node; do
    if [ -x "$candidate" ]; then NODE_BIN="$candidate"; break; fi
  done
fi

if [ -z "$NODE_BIN" ] || [ ! -x "$NODE_BIN" ]; then
  echo '{"error":"Node.js not found. Install Node.js 20+ to run Open Design."}' >&2
  exit 1
fi

# Resolve OD binary
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
OD_BIN="${OPEN_DESIGN_OD_BIN:-}"

if [ -z "$OD_BIN" ]; then
  # Try npm global
  if [ -x "$SCRIPT_DIR/../../node_modules/.bin/od" ]; then
    OD_BIN="$SCRIPT_DIR/../../node_modules/.bin/od"
  # Try sibling open-design repo
  elif [ -f "$SCRIPT_DIR/../../../../open-design/apps/daemon/bin/od.mjs" ]; then
    OD_BIN="$SCRIPT_DIR/../../../../open-design/apps/daemon/bin/od.mjs"
  fi
fi

if [ -z "$OD_BIN" ]; then
  echo '{"error":"Open Design not found. Install: cd ~/Sites/Github/open-design && pnpm install && pnpm --filter @open-design/daemon build"}' >&2
  exit 1
fi

# Resolve project root for node_modules resolution
if [[ "$OD_BIN" == *.mjs ]]; then
  OD_ROOT="$(cd "$(dirname "$OD_BIN")/../../.." && pwd)"
  cd "$OD_ROOT"
fi

exec "$NODE_BIN" "$OD_BIN" "$@"
